{
    "name": "lartisan/laravel-mailgun-client",
    "description": "A clean Laravel HTTP client for the Mailgun API, with mailing list management and newsletter sending support.",
    "keywords": ["mailgun", "laravel", "email", "newsletter", "mailing-list"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Cristian Iosif",
            "email": "cristianiosif@me.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/log": "^11.0|^12.0|^13.0",
        "guzzlehttp/promises": "^2.0",
        "symfony/http-client": "^8.0",
        "symfony/mailgun-mailer": "^8.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Lartisan\\MailgunClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lartisan\\MailgunClient\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Lartisan\\MailgunClient\\MailgunServiceProvider"
            ],
            "aliases": {
                "Mailgun": "Lartisan\\MailgunClient\\Facades\\Mailgun"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
